  "pattern_rules": [
    {
      "regex": "InfantryTerrorist|VehicleBombTruck|CombatBikeTerrorist",
      "archetype": "suicide"
    },
    {
      "regex": "Jet|A10Thunderbolt|B52|StealthFighter|Raptor|Aurora|MIG",
      "archetype": "air_plane"
    },
    {
      "regex": "VehicleComanche|VehicleHelix|Helix",
      "archetype": "air_helicopter"
    },
    {
      "regex": "VehicleTomahawk|VehicleInfernoCannon|VehicleNukeLauncher|VehicleRocketBuggy|VehicleScudLauncher",
      "archetype": "artillery"
    },
    {
      "regex": "TankOverlord|TankPaladin|TankMarauder",
      "archetype": "tank_heavy"
    },
    {
      "regex": "TankBattleMaster|TankCrusader|TankScorpion|LightTank|TankDragon",
      "archetype": "tank_medium"
    },
    {
      "regex": "TankGattling|VehicleQuadCannon|TankAvenger|GattlingCannon",
      "archetype": "vehicle_anti_air"
    },
    {
      "regex": "InfantryMissileDefender|InfantryTankHunter|InfantryStingerSoldier|InfantryTunnelDefender",
      "archetype": "infantry_rocket"
    },
    {
      "regex": "InfantryPathfinder|InfantryJarmenKell|InfantryBlackLotus|InfantryHijacker|InfantrySaboteur|InfantryColonelBurton",
      "archetype": "infantry_elite"
    },
    {
      "regex": "VehicleTechnical|VehicleHumvee|VehicleBattleBus|VehicleTroopCrawler|VehicleListeningOutpost|VehicleCombatBike|VehicleMedic|VehicleSentryDrone",
      "archetype": "vehicle_light"
    },
    {
      "regex": "Infantry|AngryMob|Ranger|Redguard|Rebel|MiniGunner|Officer|SecretService|Pilot|Worker|Hacker|Agent",
      "archetype": "infantry_rifle"
    },
    {
      "regex": "Dozer|SupplyTruck|Chinook|CargoPlane|BattleDrone|ScoutDrone|SpyDrone|RepairDrone|RadarVan|Microwave",
      "archetype": "support"
    }
  ]
